# Vance Library Data & Extracted Components
/300 Awwwards components/
# Ignore everything under public/components/ by default
/public/components/**

# Whitelist the category and component folders so Git can traverse them
!/public/components/*/
!/public/components/*/*/
!/public/components/*/*/extracted/

# Whitelist everything under extracted/ so Git tracks all precompiled and static files (e.g. styles.css)
!/public/components/*/*/extracted/**

# But ignore node_modules under extracted/
/public/components/*/*/extracted/**/node_modules/

