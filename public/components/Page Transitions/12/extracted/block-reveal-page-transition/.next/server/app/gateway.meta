{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/gateway/layout,_N_T_/gateway/page,_N_T_/gateway"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/gateway/__PAGE__",
    "/gateway",
    "/_index",
    "/_head"
  ]
}